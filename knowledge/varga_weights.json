  "varga_vimshopaka": {
    "description": "20-point strength scoring system for planets across vargas",
    "scoring": {
      "exaltation": "20 points - Highest strength",
      "moolatrikona": "18 points - Very strong",
      "own_house": "15 points - Strong",
      "great_friend": "12 points - Good strength",
      "friend": "10 points - Moderate strength",
      "neutral": "8 points - Average",
      "enemy": "5 points - Weak",
      "great_enemy": "3 points - Very weak",
      "debilitation": "0 points - No strength"
    }
  },
  "planetary_strength_calculation": {
    "description": "Calculate weighted strength of planet across all 16 vargas",
    "formula": "Sum of (Varga Score × Varga Weight) / Total Weights",
    "interpretation": {
      "above_15": "Very Strong - Planet gives excellent results",
      "10_to_15": "Strong - Planet gives good results",
      "6_to_10": "Moderate - Mixed results, effort required",
      "below_6": "Weak - Planet struggles to give results"
    }
  },
  "marriage_specific_vargas": {
    "primary": {
      "D1": "Physical and general compatibility",
      "D9": "Inner nature, soul-level compatibility, spouse's true nature",
      "D7": "Children and creative legacy together",
      "D60": "Past-life karmic connection and debt"
    },
    "weight_formula": {
      "description": "For marriage, emphasize D9 and D60",
      "calculation": "(D1 × 3 + D9 × 2.5 + D7 × 1.5 + D60 × 2) / 9"
    }
  },
