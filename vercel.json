{
    "functions": {
        "api/v1/[endpoint].ts": {
            "maxDuration": 30,
            "includeFiles": "public/swisseph.wasm"
        },
        "api/mcp.ts": {
            "maxDuration": 30
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/api/send-email", "destination": "/api/notify" },
        { "source": "/api/send-push", "destination": "/api/notify" },
        {
            "source": "/api/v1/:endpoint",
            "destination": "/api/v1/[endpoint]"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/.well-known/(.*)",
            "destination": "/.well-known/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
