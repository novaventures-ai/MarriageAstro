# =============================================================================
# MarriageAstro Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Google Gemini AI ---
# Get from: https://aistudio.google.com/app/apikey
# For development only (client-side). In production, set GEMINI_API_KEY in Vercel env vars.
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# --- Google Maps ---
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Places API" and "Maps JavaScript API"
# IMPORTANT: Restrict this key in Google Cloud Console:
#   1. Go to APIs & Services → Credentials → Edit your API key
#   2. Under "Application restrictions", select "HTTP referrers (websites)"
#   3. Add your domains: astro-marriage.vercel.app/*, localhost:3001/*
#   4. Under "API restrictions", restrict to: Places API, Maps JavaScript API
#   This prevents unauthorized usage if the key is exposed in client-side code.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================================
# Vercel Server-Side Only (set in Vercel Dashboard → Settings → Environment Variables)
# =============================================================================
# GEMINI_API_KEY=your-gemini-api-key-here    (used by /api/gemini serverless proxy)
# SUPABASE_URL=https://your-project.supabase.co  (used by /api/keep-alive)
# SUPABASE_ANON_KEY=your-anon-key-here           (used by /api/keep-alive)
